WANDB_PROJECT=model-port
# Required for W&B Registry linking. Use a W&B team/entity, not a personal
# account entity, otherwise Registry collections remain empty.
WANDB_ENTITY=
WANDB_REGISTRY_NAME=Model
WANDB_ARTIFACT_TYPE=model
WANDB_BASE_URL=http://localhost:8081
# Get this from the local W&B UI at http://localhost:8081, or use a cloud key
# only when WANDB_BASE_URL points to https://api.wandb.ai. The key must be 40+
# chars; the W&B SDK rejects shorter keys.
WANDB_API_KEY=
WANDB_PORT=8081
# offline = log runs/artifacts locally (no key needed); switch to "online" to
# sync to the local W&B server once WANDB_API_KEY holds a valid 40+ char key.
WANDB_MODE=offline
MODEL_PORT_ENV=local
MODEL_PORT_API_PORT=18080
# json keeps the transparent MVP registry. Switch to sqlite for local
# production-style promotion state and file-level locking.
MODEL_PORT_REGISTRY_BACKEND=json
# Optional. Defaults to artifacts/registry/models.json for json and
# artifacts/registry/models.db for sqlite.
MODEL_PORT_REGISTRY_PATH=
